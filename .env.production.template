# Production Environment Configuration Template

# ==========================================
# SPA MANAGEMENT SYSTEM - PRODUCTION CONFIG
# ==========================================

# Environment
NODE_ENV=production
VITE_APP_ENV=production

# Database Configuration
DATABASE_TYPE=mysql
DATABASE_HOST=db.spalotus.vn
DATABASE_PORT=3306
DATABASE_NAME=spa_management
DATABASE_USERNAME=spa_admin
DATABASE_PASSWORD=[REPLACE_WITH_SECURE_PASSWORD]

# Authentication
JWT_SECRET=[REPLACE_WITH_STRONG_SECRET_KEY_32_CHARS_MIN]
JWT_EXPIRES_IN=24h
BCRYPT_ROUNDS=12

# API Configuration
API_BASE_URL=https://api.spalotus.vn
API_VERSION=v1
CORS_ORIGIN=https://app.spalotus.vn

# External Services
GOOGLE_MAPS_API_KEY=[REPLACE_WITH_GOOGLE_MAPS_API_KEY]
GOOGLE_PLACES_API_KEY=[REPLACE_WITH_GOOGLE_PLACES_API_KEY]

# SMS Gateway (Vietnam)
SMS_PROVIDER=Vietguys
SMS_API_KEY=[REPLACE_WITH_SMS_API_KEY]
SMS_API_SECRET=[REPLACE_WITH_SMS_API_SECRET]
SMS_BRAND_NAME=LotusSpa

# Email Service
EMAIL_PROVIDER=SendGrid
EMAIL_API_KEY=[REPLACE_WITH_SENDGRID_API_KEY]
EMAIL_FROM=support@spalotus.vn
EMAIL_FROM_NAME=Lotus Spa Support

# Payment Gateway
PAYMENT_PROVIDER=VNPay
PAYMENT_MERCHANT_ID=[REPLACE_WITH_VNPAY_MERCHANT_ID]
PAYMENT_SECRET_KEY=[REPLACE_WITH_VNPAY_SECRET_KEY]
PAYMENT_RETURN_URL=https://app.spalotus.vn/payment/callback
PAYMENT_IPN_URL=https://api.spalotus.vn/payment/ipn

# Alternative Payment Methods
MOMO_API_KEY=[REPLACE_WITH_MOMO_API_KEY]
ZALOPAY_APP_ID=[REPLACE_WITH_ZALOPAY_APP_ID]
ZALOPAY_KEY1=[REPLACE_WITH_ZALOPAY_KEY1]

# File Storage
FILE_STORAGE_PROVIDER=Cloudinary
CLOUDINARY_CLOUD_NAME=[REPLACE_WITH_CLOUDINARY_CLOUD_NAME]
CLOUDINARY_API_KEY=[REPLACE_WITH_CLOUDINARY_API_KEY]
CLOUDINARY_API_SECRET=[REPLACE_WITH_CLOUDINARY_API_SECRET]

# Redis/Cache
REDIS_HOST=redis.spalotus.vn
REDIS_PORT=6379
REDIS_PASSWORD=[REPLACE_WITH_REDIS_PASSWORD]
CACHE_TTL=3600

# Monitoring & Analytics
SENTRY_DSN=[REPLACE_WITH_SENTRY_DSN]
ANALYTICS_ID=[REPLACE_WITH_GOOGLE_ANALYTICS_ID]

# Business Information
SPA_NAME=Lotus Spa
SPA_ADDRESS=71 Bồ Đề, Bồ Đề, Long Biên, Hà Nội
SPA_PHONE=0933251983
SPA_EMAIL=info@spalotus.vn
SPA_WEBSITE=https://spalotus.vn
SPA_TAX_ID=[REPLACE_WITH_TAX_ID]

# Social Media
FACEBOOK_PAGE=https://facebook.com/spalotus
INSTAGRAM_PAGE=https://instagram.com/spalotus
ZALO_OA_ID=[REPLACE_WITH_ZALO_OA_ID]

# Security
FIREWALL_IP_WHITELIST=103.21.0.0/16,103.22.0.0/16
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX_REQUESTS=100

# Backup
BACKUP_SCHEDULE=0 2 * * *  # Daily at 2 AM
BACKUP_RETENTION_DAYS=30
BACKUP_S3_BUCKET=spa-backups

# Logging
LOG_LEVEL=info
LOG_FILE=/var/log/spa-app/app.log
LOG_MAX_SIZE=10m
LOG_MAX_FILES=5

# Performance
MAX_CONNECTIONS=100
CONNECTION_TIMEOUT=30000
QUERY_TIMEOUT=30000

# ==========================================
# SECURITY NOTES:
# 1. Never commit this file to version control
# 2. Use strong, unique passwords for all services
# 3. Rotate API keys regularly
# 4. Enable 2FA for all admin accounts
# 5. Use environment-specific configurations
# ==========================================</content>
